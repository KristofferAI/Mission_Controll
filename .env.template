# Mission Controll — Environment Config
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# === THE ODDS API ===
ODDS_API_KEY=your_odds_api_key_here

# === OPTIONAL: Gamdom API key ===
GAMDOM_API_KEY=

# === OPTIONAL: override default DB path (default: data/mc.db) ===
MC_DB_PATH=

# === OddsBot — Auto-betting Config ===
# Auto-place bets uten manuell godkjenning
AUTO_PLACE_BETS=true

# Alltid paper trading (aldri ekte penger)
PAPER_MODE=true

# Maks antall bets per dag
DAILY_BET_LIMIT=10

# Minimum edge % for auto-plassering
MIN_EDGE_FOR_AUTO=3.0

# Kelly fraction (0.25 = Quarter-Kelly)
KELLY_FRACTION=0.25

# === OddsBot — Telegram notifications ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === Legacy: API-Football v3 (ikke lenger i bruk) ===
# API_FOOTBALL_KEY=your_api_football_key_here
